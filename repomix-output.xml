const icons: Record<string, React.ComponentType<any>> = {
  terminal: Terminal,
  tech: Code,
  business: Briefcase,
  science: FlaskConical,
  design: Palette,
  languages: Languages,
  marketing: TrendingUp,
  health: Activity,
  math: Calculator,
  arts: Type,
  default: HelpCircle
};

export const getIconComponent = (iconName: string | null | undefined) => {
